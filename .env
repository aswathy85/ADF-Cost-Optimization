# Copy to .env and fill in your values — never commit .env to source control

AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-secret
AZURE_TENANT_ID=your-tenant-id

# Anthropic API key for Gen AI optimization suggestions
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: override subscription list (comma-separated)
# AZURE_SUBSCRIPTION_IDS=sub-id-1,sub-id-2
